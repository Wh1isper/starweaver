{
  "servers": {
    "docs": {
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@example/docs-mcp"],
      "env": {},
      "include_instructions": true,
      "instructions": "Prefer documentation evidence for documentation questions.",
      "tools": [
        {
          "name": "lookup",
          "description": "Look up documentation by query.",
          "parameters": {
            "type": "object",
            "properties": {
              "query": {"type": "string"}
            },
            "required": ["query"]
          }
        }
      ]
    }
  }
}
